# File này chứa secrets — KHÔNG commit lên git.
# Paste RGAPI key (Riot, dùng cho login Account-V1) vào đây.
RIOT_API_KEY=RGAPI-69e3a052-0e2f-45a4-82ec-7686d8f38946

# Paste HDEV key (Henrik, dùng để fetch match details) vào đây.
# Lấy key tại https://api.henrikdev.xyz/dashboard
HENRIK_API_KEY=HDEV-ac6c6deb-8ffc-4ca6-9b4d-49001b8b8622

# LLM coach (cá nhân hoá Recommendations + bot AI chat).
# App auto detect provider từ prefix key:
#   sk-ant-...  → Anthropic Claude
#   sk-...      → OpenAI (cần billing, free credit thường đã hết)
#   AIza...     → Google Gemini (có free tier 15 req/min cho gemini-2.0-flash)
# Lấy Gemini key tại https://aistudio.google.com/apikey (free, không cần thẻ).
# Để trống LLM_API_KEY nếu muốn app fallback template tĩnh, không gọi LLM.
LLM_API_KEY=AIzaSyDCp5ZPTVFoqexcNsQU9tmS9NMtjwujAQw
# LLM_PROVIDER=gemini           # optional, auto detect theo prefix key
# LLM_MODEL=gemini-2.5-flash-lite  # optional; openai default = gpt-4o-mini, gemini default = gemini-2.5-flash-lite
#                                  Các model Gemini phổ biến (account có thể khác):
#                                    gemini-2.5-flash-lite  — default (15 RPM, 1000 RPD)
#                                    gemini-2.0-flash-lite  — backup nếu 2.5 hết quota
#                                    gemini-2.0-flash       — chất lượng cao hơn, quota chặt hơn (10 RPM, 250 RPD)
#                                    gemini-flash-latest    — model mới nhất, quota theo từng account
# LLM_CACHE_MINUTES=60          # optional, default 60 phút
